DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_ENV=development

RUN_MIGRATIONS_ON_STARTUP=true
CREATE_SUPERUSER_ON_STARTUP=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

SQLITE_NAME_DEV=db.sqlite3

POSTGRES_LOCAL_DB=django_blog_local
POSTGRES_LOCAL_USER=django_blog_local
POSTGRES_LOCAL_PASSWORD=change-me-local-postgres-password
POSTGRES_LOCAL_PORT=5432

DB_ENGINE_PROD=django.db.backends.postgresql
DB_NAME_PROD=django_blog_prod
DB_USER_PROD=django_blog_prod
DB_PASSWORD_PROD=change-me-prod-postgres-password
DB_HOST_PROD=prod-postgres-host
DB_PORT_PROD=5432

USE_S3_STORAGE=False

AWS_ACCESS_KEY_ID_DEV=change-me-dev-minio-access-key
AWS_SECRET_ACCESS_KEY_DEV=change-me-dev-minio-secret-key
AWS_STORAGE_BUCKET_NAME_DEV=djangoblogdev
AWS_S3_ENDPOINT_URL_DEV=https://minio.example.com
AWS_S3_REGION_NAME_DEV=us-east-1
AWS_S3_CUSTOM_DOMAIN_DEV=minio.example.com/djangoblogdev
AWS_S3_ADDRESSING_STYLE_DEV=path
AWS_QUERYSTRING_AUTH_DEV=False
AWS_LOCATION_DEV=media

AWS_ACCESS_KEY_ID_PROD=change-me-prod-minio-access-key
AWS_SECRET_ACCESS_KEY_PROD=change-me-prod-minio-secret-key
AWS_STORAGE_BUCKET_NAME_PROD=djangoblogprod
AWS_S3_ENDPOINT_URL_PROD=https://minio.example.com
AWS_S3_REGION_NAME_PROD=us-east-1
AWS_S3_CUSTOM_DOMAIN_PROD=minio.example.com/djangoblogprod
AWS_S3_ADDRESSING_STYLE_PROD=path
AWS_QUERYSTRING_AUTH_PROD=False
AWS_LOCATION_PROD=media

MAX_COVER_IMAGE_SIZE=5242880
